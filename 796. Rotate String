class Solution:
    def rotateString(self, s: str, goal: str) -> bool:
        
        # Step 1: Length check
        if len(s) != len(goal):
            return False
        
        # Step 2: Combine string
        combined = s + s
        
        # Step 3: Check substring
        if goal in combined:
            return True
        else:
            return False
