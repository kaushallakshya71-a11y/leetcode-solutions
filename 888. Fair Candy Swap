class Solution:
    def fairCandySwap(self, aliceSizes, bobSizes):
        
        sumA = sum(aliceSizes)
        sumB = sum(bobSizes)
        
        diff = (sumB - sumA) // 2
        
        bob_set = set(bobSizes)
        
        for x in aliceSizes:
            y = x + diff
            if y in bob_set:
                return [x, y]
