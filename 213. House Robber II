class Solution:
    def rob(self, nums: list[int]) -> int:
        
        if len(nums) == 1:
            return nums[0]
        
        def helper(arr):
            prev1 = 0
            prev2 = 0
            
            for num in arr:
                temp = max(prev1, prev2 + num)
                prev2 = prev1
                prev1 = temp
            
            return prev1
        
        case1 = helper(nums[:-1])
        case2 = helper(nums[1:])
        
        return max(case1, case2)
