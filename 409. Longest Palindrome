class Solution:
    def longestPalindrome(self, s):
        
        freq = {}
        
        for c in s:
            freq[c] = freq.get(c, 0) + 1
        
        length = 0
        
        for count in freq.values():
            length += (count // 2) * 2
        
        if length < len(s):
            length += 1
        
        return length
