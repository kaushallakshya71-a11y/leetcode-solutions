class Solution:
    def findErrorNums(self, nums):
        
        s = set()
        duplicate = -1
        
        for num in nums:
            if num in s:
                duplicate = num
            s.add(num)
        
        for i in range(1, len(nums)+1):
            if i not in s:
                missing = i
        
        return [duplicate, missing]
